{
  "enabledMcpjsonServers": [],
  "disabledMcpjsonServers": [],
  "attribution": {
    "commit": "",
    "pr": ""
  },

  "env": {
    "MAX_MCP_OUTPUT_TOKENS": "50000",
    "CLAUDE_CODE_FILE_READ_MAX_OUTPUT_TOKENS": "100000",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },

  "permissions": {
    "defaultMode": "plan",
    "additionalDirectories": [],

    "allow": [
      "Read(**)",
      "Edit(**)",
      "MultiEdit(**)",
      "Write(**)",
      "Glob(**)",
      "Grep(**)",
      "LS(**)",
      "NotebookRead(**)",
      "NotebookEdit(**)",

      "Bash"
    ],
    "ask": [
      "Bash(git push:*)",
      "Bash(git rebase:*)",
      "Bash(git reset --hard:*)",

      "Bash(docker :*)",
      "Bash(kubectl :*)",
      "Bash(aws :*)",
      "Bash(gcloud :*)",
      "Bash(az :*)",
      "Bash(terraform :*)",
      "Bash(systemctl :*)"
    ],
    "deny": [
      "Bash(rm -rf /)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~)",
      "Bash(rm -rf ~/*)",
      "Bash(sudo:*)",
      "Bash(dd if=:*)",
      "Bash(mkfs:*)",
      "Bash(diskutil :*)",
      "Bash(shutdown:*)",
      "Bash(reboot:*)",

      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)",
      "Write(./.env)",
      "Write(./.env.*)",
      "Write(./secrets/**)"
    ]
  },
  "statusLine": {
    "type": "command",
    "command": ".claude/statusline.sh",
    "padding": 0
  },
  "spinnerTipsOverride": {
    "tips": [
      "Ejecuta /project-init al iniciar un proyecto o tras cambios importantes en dependencias",
      "Usa /commit y /pull-request para operaciones git — imponen quality gates automáticos",
      "Invoca /scenario-driven-development para cualquier feature, fix o cambio",
      "Ejecuta /verification-before-completion antes de declarar cualquier tarea como terminada",
      "Ajusta /effort high o /effort max para máximo razonamiento — el default (medium) deja capacidad sobre la mesa"
    ]
  }
}
